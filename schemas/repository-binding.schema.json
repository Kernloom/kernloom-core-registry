{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernloom.dev/schemas/repository-binding.schema.json",
  "title": "Kernloom repository binding",
  "type": "object",
  "required": ["kind", "spec"],
  "properties": {
    "kind": { "enum": ["RepositoryBindingSet"] },
    "metadata": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": ["repositories"],
      "properties": {
        "repositories": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "type", "provider", "org", "repo"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "type": { "type": "string", "minLength": 1 },
              "provider": { "type": "string", "minLength": 1 },
              "org": { "type": "string", "minLength": 1 },
              "repo": { "type": "string", "minLength": 1 },
              "default_branch": { "type": "string", "minLength": 1 },
              "owner_team": { "type": "string", "minLength": 1 },
              "visibility": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
