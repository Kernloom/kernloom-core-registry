{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernloom.dev/schemas/business-action.schema.json",
  "title": "Kernloom business action",
  "type": "object",
  "required": ["application", "actions"],
  "properties": {
    "application": {
      "type": "object",
      "required": ["id", "tenant", "environment"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "tenant": { "type": "string", "minLength": 1 },
        "environment": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "canonical_action", "type", "sensitivity"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "canonical_action": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "sensitivity": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "approval": { "type": "object", "additionalProperties": true },
          "bindings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "target_ref", "capability", "selector"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "target_ref": { "type": "string", "minLength": 1 },
                "capability": { "type": "string", "minLength": 1 },
                "selector": { "type": "object", "additionalProperties": true },
                "controls": { "type": "array", "items": { "type": "string", "minLength": 1 } },
                "proof": { "type": "object", "additionalProperties": true },
                "approval": { "type": "object", "additionalProperties": true }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
