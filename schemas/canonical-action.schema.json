{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernloom.dev/schemas/canonical-action.schema.json",
  "title": "Kernloom canonical action",
  "type": "object",
  "required": ["kind", "spec"],
  "properties": {
    "kind": { "enum": ["CanonicalActionCatalog"] },
    "metadata": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": ["actions"],
      "properties": {
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "type", "sensitivity"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "type": { "type": "string", "minLength": 1 },
              "sensitivity": { "enum": ["low", "medium", "high", "critical"] },
              "owner": { "type": "string", "minLength": 1 },
              "description": { "type": "string" },
              "required_controls": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "required_events": { "type": "array", "items": { "type": "string", "minLength": 1 } }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
