{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernloom.dev/schemas/registry.schema.json",
  "title": "Kernloom Registry Document",
  "type": "object",
  "required": ["kind", "metadata", "spec"],
  "properties": {
    "kind": { "type": "string" },
    "metadata": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "string" }
      },
      "additionalProperties": true
    },
    "spec": { "type": "object" }
  },
  "additionalProperties": false
}

