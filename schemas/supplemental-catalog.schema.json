{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernloom.dev/schemas/supplemental-catalog.schema.json",
  "title": "Kernloom supplemental catalog",
  "type": "object",
  "required": ["kind", "spec"],
  "properties": {
    "kind": { "enum": ["SignalCatalog", "MetricCatalog", "GranularityCatalog", "EntityTypeCatalog", "ActionTypeCatalog", "EvidenceCatalog", "PrivilegeCatalog", "StateCatalog", "EventCatalog", "ContextCatalog", "ComponentRoleCatalog", "RequirementCatalog", "SelectorSchemaCatalog", "ValidationProfileCatalog"] },
    "metadata": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": ["entries"],
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "status": { "enum": ["experimental", "stable", "deprecated", "planned"] },
              "kind": { "type": "string", "minLength": 1 },
              "description": { "type": "string" },
              "schema": { "type": "object", "additionalProperties": true },
              "required_metrics": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "required_signals": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "required_capabilities": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "required_evidence": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "allowed_granularities": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "unknown_behavior": { "enum": ["risk_unknown", "fail_closed", "unsupported", "observe_only"] }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
